{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "outputDirectory": ".next",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.homefinishline.com" }],
      "destination": "https://homefinishline.com/:path*",
      "permanent": true
    }
  ]
}
